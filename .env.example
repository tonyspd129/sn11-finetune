# ─── scaffold harness + sandbox runner — environment ─────────────────────────
# Copy to `.env`. sandbox.py auto-loads it; a set shell var still wins.

# ── Model endpoint (required) ────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=qwen3.6-35b-a3b
LLM_API_KEY=sk-local
# OPENROUTER_API_KEY=sk-or-...      # alt key var (OpenRouter is the default backend)

# ── Agent run budgets (optional; defaults shown) ─────────────────────────────
# AGENT_WORKDIR=/workspace          # sandbox overrides this to the image WORKDIR
# MAX_TURNS=40
# MAX_TOKENS_BUDGET=                 # unset = unlimited
# WALL_CLOCK_S=                      # unset = unlimited

# ── Sampling (optional; defaults shown) ──────────────────────────────────────
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=4096

# ── Sandbox batch runner (optional; defaults shown) ──────────────────────────
# SANDBOX_PARALLEL=1                 # concurrent tasks; bottleneck is docker build, not the LLM
# SANDBOX_NETWORK=                   # e.g. `none` to isolate; unset = docker default
# BUILD_TIMEOUT=1800
# VERIFY_TIMEOUT=900                 # on timeout: score 0, session still exported

# ── Notes ────────────────────────────────────────────────────────────────────
# - Agent runs host-side; the host needs `openai` (uv run python sandbox.py).
# - tools / skills / prompt / compaction come from the scaffold package, not env.
