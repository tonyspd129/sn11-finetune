# ─── scaffold harness — environment ──────────────────────────────────────────
# Copy to `.env` and fill in. The harness reads these from the OS environment
# (scaffold/llm.py → LLMClient). Nothing auto-loads `.env` yet, so load it with:
#     set -a; source .env; set +a
# The sandbox harness (eval/sandbox.py) also takes the model endpoint via CLI:
#     --llm-base-url / --llm-model / --llm-key   (these override the env)

# ── Model endpoint (required to run the agent) ───────────────────────────────
# OpenAI-compatible endpoint serving the model. Local vLLM example:
LLM_BASE_URL=http://localhost:8000/v1
# The id the endpoint serves the model under (vLLM: its --served-model-name).
LLM_MODEL=qwen3.6-35b-a3b
# API key. For a local vLLM any non-empty string works; for OpenRouter use the real key.
LLM_API_KEY=sk-local
# Alternative key var the client also accepts (OpenRouter is the default backend):
# OPENROUTER_API_KEY=sk-or-...

# ── Agent run budgets (optional; defaults shown) ─────────────────────────────
# Working dir the agent's tools act in. The sandbox overrides this to the task
# image's WORKDIR; only relevant if you run the harness directly.
# AGENT_WORKDIR=/workspace
# Max think→act→observe iterations before the loop stops.
# MAX_TURNS=40
# Token budget (prompt+completion) before the loop stops. Unset = unlimited.
# MAX_TOKENS_BUDGET=
# Wall-clock budget in seconds before the loop stops. Unset = unlimited.
# WALL_CLOCK_S=

# ── Sampling (optional; defaults shown) ──────────────────────────────────────
# Sampling temperature. 0.0 = greedy (most reproducible).
# LLM_TEMPERATURE=0.0
# Max tokens per model response.
# LLM_MAX_TOKENS=4096

# ── Notes ────────────────────────────────────────────────────────────────────
# - Precedence for every knob: explicit code arg > env (these) > built-in default.
#   In the competition the validator injects these via env; here .env is that source.
# - tools / skills / system prompt / compaction load from the scaffold package
#   files, NOT from env — there are no env knobs for them.
